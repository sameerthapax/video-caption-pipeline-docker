# GemmaCaption-Pipe defaults
LLM_PROVIDER=openrouter
OPENROUTER_MODEL=google/gemma-4-31b-it
OPENROUTER_API_KEY=

# Independent quality judge
JUDGE_LLM_PROVIDER=fireworks
JUDGE_MODEL=accounts/fireworks/models/kimi-k2p6
FIREWORKS_API_KEY=

# Optional Cloudflare proxy. Leave blank when using provider API keys directly.
OPENROUTER_PROXY_URL=
OPENROUTER_PROXY_TOKEN=
FIREWORKS_PROXY_URL=
FIREWORKS_PROXY_TOKEN=

# Pipeline controls
MAX_CONCURRENT_JOBS=3
MAX_FRAMES_PER_VIDEO=12
CAPTION_ACCEPTANCE_THRESHOLD=0.94
FIREWORKS_TIMEOUT_SECONDS=120
FIREWORKS_QUEUE_TIMEOUT_SECONDS=60
FIREWORKS_MAX_RETRIES=2
FIREWORKS_VISION_MAX_TOKENS=20000
FIREWORKS_CAPTION_MAX_TOKENS=20000
FIREWORKS_JUDGE_MAX_TOKENS=20000
FIREWORKS_CREATIVE_TEMPERATURE=0.4
LOG_MODEL_IO=false
