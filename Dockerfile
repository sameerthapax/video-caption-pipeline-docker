FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

ARG LLM_PROVIDER="fireworks"
ARG FIREWORKS_MODEL="accounts/fireworks/models/kimi-k2p6"
ARG FIREWORKS_PROXY_URL="https://caption-proxy.hackathon-caption-pipe.workers.dev"
ARG FIREWORKS_PROXY_TOKEN="1f633ad1c7aabec805dd3cec23486fa0f809e8d7b51aaf1347408d6c784c216f"
ARG OPENROUTER_MODEL="openai/gpt-5.6-sol"
ARG OPENROUTER_PROXY_URL="https://caption-proxy.hackathon-caption-pipe.workers.dev/openrouter"
ARG OPENROUTER_PROXY_TOKEN="1f633ad1c7aabec805dd3cec23486fa0f809e8d7b51aaf1347408d6c784c216f"
ARG FIREWORKS_REASONING_EFFORT="none"
ARG FIREWORKS_VISION_MAX_TOKENS="300"
ARG FIREWORKS_CAPTION_MAX_TOKENS="180"
ARG FIREWORKS_JUDGE_MAX_TOKENS="200"
ARG CAPTION_PIPELINE_MODE="verified_scene"
ARG OBSERVATION_CAPTION_MODE="combined"
ARG ENABLE_VIDEO_NORMALIZATION="false"
ARG MAX_FRAMES_PER_VIDEO="3"
ARG ENABLE_PLANNED_FRAME_EXTRACTION="false"
ARG MAX_CONCURRENT_JOBS="3"
ARG RUN_JUDGE_CHECKS="false"
ARG LOG_MODEL_IO="false"

ENV LLM_PROVIDER=${LLM_PROVIDER}
ENV FIREWORKS_MODEL=${FIREWORKS_MODEL}
ENV FIREWORKS_PROXY_URL=${FIREWORKS_PROXY_URL}
ENV FIREWORKS_PROXY_TOKEN=${FIREWORKS_PROXY_TOKEN}
ENV OPENROUTER_MODEL=${OPENROUTER_MODEL}
ENV OPENROUTER_PROXY_URL=${OPENROUTER_PROXY_URL}
ENV OPENROUTER_PROXY_TOKEN=${OPENROUTER_PROXY_TOKEN}
ENV FIREWORKS_REASONING_EFFORT=${FIREWORKS_REASONING_EFFORT}
ENV FIREWORKS_VISION_MAX_TOKENS=${FIREWORKS_VISION_MAX_TOKENS}
ENV FIREWORKS_CAPTION_MAX_TOKENS=${FIREWORKS_CAPTION_MAX_TOKENS}
ENV FIREWORKS_JUDGE_MAX_TOKENS=${FIREWORKS_JUDGE_MAX_TOKENS}
ENV CAPTION_PIPELINE_MODE=${CAPTION_PIPELINE_MODE}
ENV OBSERVATION_CAPTION_MODE=${OBSERVATION_CAPTION_MODE}
ENV ENABLE_VIDEO_NORMALIZATION=${ENABLE_VIDEO_NORMALIZATION}
ENV MAX_FRAMES_PER_VIDEO=${MAX_FRAMES_PER_VIDEO}
ENV ENABLE_PLANNED_FRAME_EXTRACTION=${ENABLE_PLANNED_FRAME_EXTRACTION}
ENV MAX_CONCURRENT_JOBS=${MAX_CONCURRENT_JOBS}
ENV RUN_JUDGE_CHECKS=${RUN_JUDGE_CHECKS}
ENV LOG_MODEL_IO=${LOG_MODEL_IO}

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ffmpeg ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN mkdir -p /input /output

ENTRYPOINT ["python", "main.py"]
